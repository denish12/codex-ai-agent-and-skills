{
  "name": "code-ai-installer",
  "version": "1.3.1",
  "description": "Production-ready CLI to install code-ai agents and skills for multiple AI coding assistants.",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "AGENTS.yaml",
    "agents",
    ".agents",
    "locales"
  ],
  "bin": {
    "code-ai": "dist/index.js"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); if (fs.existsSync('dist')) fs.rmSync('dist',{recursive:true,force:true});\"",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepack": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "agents",
    "ai",
    "codex",
    "claude",
    "qwen",
    "copilot",
    "gemini"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "prompts": "^2.4.2",
    "yaml": "^2.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
